        }
      }
    ]
  },
  "edges_config": {
    "edges": [
      { "id": "b1", "source": "t1", "target": "c1", "animated": true },
      { "id": "b2", "source": "c1", "sourceHandle": "true", "target": "c2", "animated": true },
      { "id": "b3", "source": "c2", "sourceHandle": "true", "target": "e1", "animated": true }
    ]
  }
